<?xml version="1.0" encoding="utf-8"?>
<ScrollView  xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/main"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/light_gray_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="7dp"
        android:orientation="vertical">

        <!-- Tiêu đề -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cài đặt ngưỡng giám sát Node"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/royal_blue"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Node 1 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Node 1"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/primary_text_color"
            android:layout_marginBottom="8dp" />

        <!-- Bắt đầu block Node 1 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            android:layout_marginHorizontal="10dp"
            app:cardElevation="4dp"
            android:backgroundTint="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Cặp nhiệt độ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Nhiệt độ tối thiểu (°C)"
                        android:textSize="16sp"
                        android:textColor="@color/primary_text_color" />

                    <EditText
                        android:id="@+id/edit_temp_min1"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:hint="20"
                        android:gravity="center"
                        android:background="@drawable/edittext_background"
                        android:padding="8dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Nhiệt độ tối đa (°C)"
                        android:textSize="16sp"
                        android:textColor="@color/primary_text_color" />

                    <EditText
                        android:id="@+id/edit_temp_max1"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:hint="35"
                        android:gravity="center"
                        android:background="@drawable/edittext_background"
                        android:padding="8dp" />
                </LinearLayout>

                <!-- Cặp độ ẩm -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Độ ẩm tối thiểu (%)"
                        android:textSize="16sp"
                        android:textColor="@color/primary_text_color" />

                    <EditText
                        android:id="@+id/edit_humi_min1"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:hint="40"
                        android:gravity="center"
                        android:background="@drawable/edittext_background"
                        android:padding="8dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Độ ẩm tối đa (%)"
                        android:textSize="16sp"
                        android:textColor="@color/primary_text_color" />

                    <EditText
                        android:id="@+id/edit_humi_max1"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:hint="70"
                        android:gravity="center"
                        android:background="@drawable/edittext_background"
                        android:padding="8dp" />
                </LinearLayout>

                <!-- Cặp CO2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="CO₂ tối đa (ppm)"
                        android:textSize="16sp"
                        android:textColor="@color/primary_text_color" />

                    <EditText
                        android:id="@+id/edit_co2_max1"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:hint="1000"
                        android:gravity="center"
                        android:background="@drawable/edittext_background"
                        android:padding="8dp" />
                </LinearLayout>

                <!-- Cặp bụi mịn -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Bụi mịn tối đa (m  g/m³)"
                        android:textSize="16sp"
                        android:textColor="@color/primary_text_color" />

                    <EditText
                        android:id="@+id/edit_pm_max1"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:hint="150"
                        android:gravity="center"
                        android:background="@drawable/edittext_background"
                        android:padding="8dp" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Node 2 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Node 2"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/primary_text_color"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp" />

        <!-- Node 2 CardView -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            android:layout_marginHorizontal="10dp"
            app:cardElevation="4dp"
            android:backgroundTint="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Cặp nhiệt độ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Nhiệt độ tối thiểu (°C)"
                        android:textSize="16sp"
                        android:textColor="@color/primary_text_color" />

                    <EditText
                        android:id="@+id/edit_temp_min2"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:hint="20"
                        android:gravity="center"
                        android:background="@drawable/edittext_background"
                        android:padding="8dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Nhiệt độ tối đa (°C)"
                        android:textSize="16sp"
                        android:textColor="@color/primary_text_color" />

                    <EditText
                        android:id="@+id/edit_temp_max2"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:hint="35"
                        android:gravity="center"
                        android:background="@drawable/edittext_background"
                        android:padding="8dp" />
                </LinearLayout>

                <!-- Cặp độ ẩm -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Độ ẩm tối thiểu (%)"
                        android:textSize="16sp"
                        android:textColor="@color/primary_text_color" />

                    <EditText
                        android:id="@+id/edit_humi_min2"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:hint="40"
                        android:gravity="center"
                        android:background="@drawable/edittext_background"
                        android:padding="8dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Độ ẩm tối đa (%)"
                        android:textSize="16sp"
                        android:textColor="@color/primary_text_color" />

                    <EditText
                        android:id="@+id/edit_humi_max2"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:hint="70"
                        android:gravity="center"
                        android:background="@drawable/edittext_background"
                        android:padding="8dp" />
                </LinearLayout>

                <!-- Cặp CO2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="CO₂ tối đa (ppm)"
                        android:textSize="16sp"
                        android:textColor="@color/primary_text_color" />

                    <EditText
                        android:id="@+id/edit_co2_max2"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:hint="1000"
                        android:gravity="center"
                        android:background="@drawable/edittext_background"
                        android:padding="8dp" />
                </LinearLayout>

                <!-- Cặp bụi mịn -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Bụi mịn tối đa (m  g/m³)"
                        android:textSize="16sp"
                        android:textColor="@color/primary_text_color" />

                    <EditText
                        android:id="@+id/edit_pm_max2"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:hint="150"
                        android:gravity="center"
                        android:background="@drawable/edittext_background"
                        android:padding="8dp" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Nút Lưu -->
        <Button
            android:id="@+id/btn_save_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginHorizontal="50dp"
            android:text="Lưu tất cả cài đặt"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/royal_blue"
            android:padding="12dp" />

    </LinearLayout>

</ScrollView >
