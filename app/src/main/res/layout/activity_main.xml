<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/main"
    android:background="@color/light_gray_background"
    android:padding="16dp">

    <TextView
        android:id="@+id/txt_Title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Giám sát môi trường"
        android:textSize="25sp"
        android:textAlignment="center"
        android:textStyle="bold"
        android:layout_marginTop="10dp"
        android:textColor="@color/royal_blue"
        android:layout_marginBottom="10dp" />
    <ScrollView
        android:id="@+id/scroll_area"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/txt_Title"
        android:layout_marginHorizontal="7dp"
        android:layout_above="@+id/btn_settings_fab">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ==== NODE 1 ==== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                android:backgroundTint="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/txt_node1_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌱 Node 1 - Khu vực A"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/royal_blue"
                        android:layout_marginBottom="12dp" />

                    <!-- Nhiệt độ -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingTop="6dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="8dp"
                            android:src="@drawable/ic_temperature" />

                        <TextView
                            android:id="@+id/txt_node1_temp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nhiệt độ: -- °C"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <!-- Độ ẩm -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingTop="6dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="8dp"
                            android:src="@drawable/ic_humidity" />

                        <TextView
                            android:id="@+id/txt_node1_humi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Độ ẩm: -- %"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <!-- CO2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingTop="6dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="8dp"
                            android:src="@drawable/ic_co2" />

                        <TextView
                            android:id="@+id/txt_node1_co2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CO₂: -- ppm"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <!-- Bụi -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingTop="6dp"
                        android:paddingBottom="4dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="8dp"
                            android:src="@drawable/ic_dust" />

                        <TextView
                            android:id="@+id/txt_node1_dust"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bụi: -- mg/m³"
                            android:textSize="16sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ==== NODE 2 ==== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/txt_node2_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌱 Node 2 - Khu vực B"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/royal_blue"
                        android:layout_marginBottom="12dp" />

                    <!-- Nhiệt độ -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingTop="6dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="8dp"
                            android:src="@drawable/ic_temperature" />

                        <TextView
                            android:id="@+id/txt_node2_temp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nhiệt độ: -- °C"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <!-- Độ ẩm -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingTop="6dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="8dp"
                            android:src="@drawable/ic_humidity" />

                        <TextView
                            android:id="@+id/txt_node2_humi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Độ ẩm: -- %"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <!-- CO2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingTop="6dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="8dp"
                            android:src="@drawable/ic_co2" />

                        <TextView
                            android:id="@+id/txt_node2_co2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CO₂: -- ppm"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <!-- Bụi -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingTop="6dp"
                        android:paddingBottom="4dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="8dp"
                            android:src="@drawable/ic_dust" />

                        <TextView
                            android:id="@+id/txt_node2_dust"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bụi: -- mg/m³"
                            android:textSize="16sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ==== NODE 3 ==== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                android:backgroundTint="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/txt_node3_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌱 Node 3 - Khu vực C"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/royal_blue"
                        android:layout_marginBottom="12dp" />

                    <!-- Nhiệt độ -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingTop="6dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="8dp"
                            android:src="@drawable/ic_temperature" />

                        <TextView
                            android:id="@+id/txt_node3_temp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nhiệt độ: -- °C"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <!-- Độ ẩm -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingTop="6dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="8dp"
                            android:src="@drawable/ic_humidity" />

                        <TextView
                            android:id="@+id/txt_node3_humi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Độ ẩm: -- %"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <!-- CO2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingTop="6dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="8dp"
                            android:src="@drawable/ic_co2" />

                        <TextView
                            android:id="@+id/txt_node3_co2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CO₂: -- ppm"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <!-- Bụi -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingTop="6dp"
                        android:paddingBottom="4dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="8dp"
                            android:src="@drawable/ic_dust" />

                        <TextView
                            android:id="@+id/txt_node3_dust"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bụi: -- mg/m³"
                            android:textSize="16sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_settings_fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="20dp"
        app:srcCompat="@drawable/ic_settings"
        app:tint="@android:color/white"
        android:contentDescription="Cài đặt"
        android:backgroundTint="@color/royal_blue" />
</RelativeLayout>